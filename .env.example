# Copia de seguridad en la nube (Supabase) — opcional
# Crea un proyecto gratis en https://supabase.com y ejecuta supabase/schema.sql + billing.sql
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon
# Solo servidor (webhook Stripe, nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL pública de la app (producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Monetización — en local dejar false para desarrollo sin límites
NEXT_PUBLIC_BILLING_ENABLED=false

# Stripe (https://stripe.com) — ver docs/DEPLOY.md
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
