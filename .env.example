# Copia a .env.local para desarrollo. En producción: Vercel → Environment Variables.
# Ver docs/FASES.md para el orden de configuración.

# --- App ---
# Producción: https://facturacion-autonomos.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.2.0

# --- Productor del SIF (TÚ como creador del software) — Fase 0/2 ---
NEXT_PUBLIC_VERIFACTU_DEVELOPER_NIF=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_NAME=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_ADDRESS=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_CITY=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_COUNTRY=España
# Ej. info@facturacion-autonomos.app
NEXT_PUBLIC_VERIFACTU_DEVELOPER_EMAIL=
NEXT_PUBLIC_VERIFACTU_SYSTEM_ID=FA
NEXT_PUBLIC_VERIFACTU_INSTALLATION_ID=FA-LOCAL
# Mantener false hasta cerrar transporte real AEAT con certificado y revisión externa.
NEXT_PUBLIC_VERIFACTU_ALLOW_PRODUCTION=false

# --- Supabase — Fase 1 ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Activa el boton "Continuar con Google" solo tras configurar Google OAuth en Supabase.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# --- Stripe (billing Pro) — Fase 3 ---
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# --- Email (Resend) — bienvenida Factu ---
RESEND_API_KEY=
# Producción: Factu - Facturación Autónomos <info@facturacion-autonomos.app>
EMAIL_FROM=Factu - Facturación Autónomos <info@facturacion-autonomos.app>
# Opcional si no usas EMAIL_FROM completo:
# EMAIL_FROM_NAME=Factu - Facturación Autónomos
# EMAIL_FROM_ADDRESS=info@facturacion-autonomos.app

# --- IA y autocompletado ---
OPENAI_API_KEY=
# Opcional: modelo de transcripción Realtime para Voz IA en recordatorios.
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
# Opcional: completa códigos postales desde dirección + ciudad en Rellenar con IA.
GOOGLE_MAPS_API_KEY=

# --- Veri*Factu servidor — Fase 5 ---
VERIFACTU_ENVIRONMENT=test
VERIFACTU_AEAT_SUBMIT=false
# personal = certificado del autónomo/empresa obligada; sello = futuro canal con apoderamiento.
VERIFACTU_AEAT_CERT_CHANNEL=personal
# Opcional para pruebas controladas; vacío usa endpoint oficial AEAT del entorno.
VERIFACTU_AEAT_ENDPOINT_URL=
VERIFACTU_CERT_P12_BASE64=
VERIFACTU_CERT_PASSWORD=
