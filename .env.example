# Copia a .env.local para desarrollo. En producción: Vercel → Environment Variables.
# Ver docs/FASES.md para el orden de configuración.

# --- App ---
# Producción: https://facturacion-autonomos.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.2.0
# Seguridad: producción bloquea CSP por defecto. Usar report-only solo para diagnóstico temporal.
SECURITY_CSP_MODE=enforce
# true registra informes CSP saneados en logs del servidor.
SECURITY_CSP_REPORT_LOGGING=true
# memory por defecto; produccion usa supabase tras aplicar server_rate_limit_buckets.
SERVER_RATE_LIMIT_BACKEND=memory
# Secreto aleatorio y exclusivo. No reutilizar URLs, emails ni otras claves.
SERVER_RATE_LIMIT_SALT=
# Vercel lo envia como Bearer al cron de alertas de seguridad.
CRON_SECRET=
# Produccion: obligatorio, lista separada por comas. No hay fallback admin en Vercel.
ADMIN_EMAILS=

# --- Vercel observabilidad admin ---
# Token privado de Vercel para que /admin muestre coste/uso. No usar NEXT_PUBLIC.
VERCEL_BILLING_API_TOKEN=
VERCEL_TEAM_ID=
# ID del proyecto para comparar main, deployment, dominio y Firewall.
VERCEL_PROJECT_ID=
# Opcional; por defecto facturacion-autonomos.app.
VERCEL_PRODUCTION_DOMAIN=facturacion-autonomos.app
# Alternativa a VERCEL_TEAM_ID si se prefiere slug de equipo.
VERCEL_BILLING_TEAM_SLUG=
VERCEL_USAGE_PROJECT_SLUG=factu-autonomo
# Opcional: alinear el ciclo visual del admin con el ciclo real visto en Vercel.
VERCEL_BILLING_CYCLE_START_DAY=15
VERCEL_BILLING_CYCLE_START_HOUR=9

# --- Productor del SIF (TÚ como creador del software) — Fase 0/2 ---
NEXT_PUBLIC_VERIFACTU_DEVELOPER_NIF=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_NAME=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_ADDRESS=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_CITY=
NEXT_PUBLIC_VERIFACTU_DEVELOPER_COUNTRY=España
# Ej. info@facturacion-autonomos.app
NEXT_PUBLIC_VERIFACTU_DEVELOPER_EMAIL=
NEXT_PUBLIC_VERIFACTU_SYSTEM_ID=FA
NEXT_PUBLIC_VERIFACTU_INSTALLATION_ID=FA-LOCAL
# Mantener false hasta cerrar transporte real AEAT con certificado y revisión externa.
NEXT_PUBLIC_VERIFACTU_ALLOW_PRODUCTION=false

# --- Supabase — Fase 1 ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: clave publica Cloudflare Turnstile para proteger registro/login.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Activa el boton "Continuar con Google" solo tras configurar Google OAuth en Supabase.
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# Google Login propio: usa el mismo client id en ambas variables si aplica.
NEXT_PUBLIC_GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
# Google Drive backup.
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
# Fallback legacy para Drive; preferir NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Stripe (billing Pro) — Fase 3 ---
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_PRO_PLUS_MONTHLY=
STRIPE_PRICE_PRO_PLUS_YEARLY=
STRIPE_PRICE_SCAN_PACK=

# --- Email (Resend) — bienvenida, recordatorios y buzón de gastos ---
RESEND_API_KEY=
# Producción Resend: usar el subdominio con DKIM verificado.
EMAIL_FROM=Factu - Facturación Autónomos <hola@mail.facturacion-autonomos.app>
# Opcional si no usas EMAIL_FROM completo:
# EMAIL_FROM_NAME=Factu - Facturación Autónomos
# EMAIL_FROM_ADDRESS=hola@mail.facturacion-autonomos.app
# Webhooks/inbound de Resend para el buzón de gastos.
RESEND_WEBHOOK_SECRET=
RESEND_INBOUND_DOMAIN=
EXPENSE_INBOX_WEBHOOK_SECRET=
EXPENSE_INBOX_DOMAIN=

# --- IA y autocompletado ---
OPENAI_API_KEY=
OPENAI_FISCAL_FALLBACK_MODEL=gpt-4o-mini
OPENAI_FISCAL_FALLBACK_TIMEOUT_MS=15000
# Opcional: modelo para Rellenar con IA en clientes. Por defecto usa gpt-4o.
OPENAI_CUSTOMER_AI_MODEL=gpt-4o
# Opcional: modelo y salida máxima para escaneo de gastos.
OPENAI_EXPENSE_SCAN_MODEL=gpt-4o
OPENAI_EXPENSE_SCAN_MAX_TOKENS=
# Opcional: modelo de transcripción Realtime para Voz IA en recordatorios.
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
# Opcional: completa códigos postales desde dirección + ciudad en Rellenar con IA.
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=
# Opcional: autocomplete de direcciones en navegador.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Veri*Factu servidor — Fase 5 ---
VERIFACTU_ENVIRONMENT=test
VERIFACTU_AEAT_SUBMIT=false
# personal = certificado del autónomo/empresa obligada; sello = futuro canal con apoderamiento.
VERIFACTU_AEAT_CERT_CHANNEL=personal
# Opcional para pruebas controladas; vacío usa endpoint oficial AEAT del entorno.
VERIFACTU_AEAT_ENDPOINT_URL=
VERIFACTU_CERT_P12_BASE64=
VERIFACTU_CERT_PASSWORD=

# --- Rutas privadas/experimentales ---
# Calendario fiscal: producción publica solo la estructura REVIEW_ONLY sin red.
# Estas variables habilitan exclusivamente pruebas locales con fixtures/Google.
FISCAL_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_API_KEY=
FISCAL_CALENDAR_LIVE_TEST=false
# Release global de la Beta; no sustituye una activación ni un entitlement de pago.
# Mantener desactivado en producción salvo revisión y aprobación explícita.
NEXT_PUBLIC_CONSULTOR_FISCAL_ENABLED=false
NEXT_PUBLIC_TAX_MODEL_DIAGNOSTIC_ENABLED=false
CONSULTOR_FISCAL_AI_FALLBACK_ENABLED=false
SERVER_DOCUMENT_INGEST_ROUTE_ENABLED=false
DOCUMENT_SYNC_ROUTE_SHELL_ENABLED=false
DOCUMENT_SYNC_ROUTE_SHELL_PRIVATE_MODE=
DOCUMENT_SYNC_ROUTE_FAKE_ADAPTER_ENABLED=false
DOCUMENT_SYNC_ROUTE_FAKE_ADAPTER_MODE=

# --- Fixtures privados de prueba (opt-in local; no usar en producción) ---
# PDF privado STIL. La ruta puede ser absoluta o relativa al checkout.
# STIL_CONDAL_FIXTURE_PDF=/ruta/privada/factura-privada.pdf
# JSON esperado privado correspondiente; debe configurarse junto al PDF.
# STIL_CONDAL_GROUND_TRUTH_JSON=/ruta/privada/factura-privada.expected.json
# Raíz que contiene exports/facturadirecta y exports/holded.
# COMPETITOR_IMPORT_FIXTURES_ROOT=/ruta/privada/competitor-import-fixtures
# Dataset externo opcional usado por los comandos real:qa:external:*.
# INVOICE_REAL_QA_EXTERNAL_ROOT=/ruta/privada/dataset-externo
