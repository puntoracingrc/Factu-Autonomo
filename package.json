{
  "name": "factura-autonomo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "check:migrations": "node scripts/check-supabase-migrations.mjs",
    "validate:phase2b2-server-schema": "node scripts/validate-phase2b2-server-schema.mjs",
    "validate:phase2b3e-ingest-route-safety": "node scripts/validate-phase2b3e-ingest-route-safety.mjs",
    "validate:phase2b3g-controlled-ingest-route": "node scripts/validate-phase2b3g-controlled-ingest-route.mjs",
    "test:phase2b3h-ingest-local": "node scripts/test-phase2b3h-supabase-local-ingest-route.mjs",
    "test:phase1-acceptance": "node scripts/phase1-acceptance/run.mjs",
    "manual:screenshots": "node scripts/capture-manual-screenshots.mjs",
    "manual:verify": "vitest run src/lib/manual/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "buffer": "^6.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.17.0",
    "mdb-reader": "^3.2.0",
    "next": "^15.5.19",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "playwright": "^1.49.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
